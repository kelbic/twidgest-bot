# --- Telegram ---
# Токен @TwidgestBot от @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Твой Telegram user_id для админских команд (узнать через @userinfobot)
ADMIN_USER_ID=123456789

# --- TwitterAPI.io ---
TWITTER_API_KEY=your_twitterapi_io_key_here

# --- OpenRouter ---
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL_DEFAULT=meta-llama/llama-3.3-70b-instruct
OPENROUTER_MODEL_PRO=anthropic/claude-sonnet-4

# --- БД ---
DATABASE_URL=sqlite+aiosqlite:///./twidgest.db

# --- Расписание (можно тонко тюнить позже) ---
COLLECT_INTERVAL_MINUTES=30

LOG_LEVEL=INFO
